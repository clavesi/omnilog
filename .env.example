DATABASE_URL=""
# direct database url without pooling (Neon requires this)
DIRECT_DATABASE_URL=""

# The Open Movie Database
TMDB_API_KEY=""

# (IGDB) Twitch API Key
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# Local dev uses `.env.development` (Docker Postgres from docker-compose.yml).
# Vite loads it automatically when running `pnpm dev`; Drizzle CLI uses it too.
# Put Neon URLs in `.env`, then run `pnpm db:migrate:neon` or `pnpm db:push:neon`.
